<Window x:Class="HiveChat.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HiveChat 🐝" Height="600" Width="460"
        Background="#181820"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2a2a3d"/>
            <Setter Property="Foreground" Value="#e0e0e8"/>
            <Setter Property="CaretBrush" Value="#e0e0e8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#5865f2"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4752c4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3c45a5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2a2a3d"/>
                                <Setter Property="Foreground" Value="#555568"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#20202c"
                CornerRadius="8"
                Padding="12,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0"
                           Text="HiveChat 🐝"
                           Foreground="#e0e0e8"
                           FontSize="22"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"/>
                
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" 
                             Width="10" Height="10" 
                             Fill="Red" 
                             Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" 
                               Text="Disconnected" 
                               Foreground="#a0a0a0" 
                               FontSize="14" 
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#20202c"
                CornerRadius="8"
                Padding="8"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="UsernameBox"
                         Style="{StaticResource RoundedTextBox}"
                         Width="220"
                         Margin="0,0,8,0"/>
                <Button x:Name="ConnectButton"
                        Content="Connect"
                        Style="{StaticResource AccentButton}"
                        Click="ConnectButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#20202c"
                CornerRadius="8"
                Padding="6"
                Margin="0,0,0,12">
            <ListBox x:Name="MessagesList"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Border x:Name="MessageBorder"
                                    CornerRadius="10"
                                    Padding="10,8"
                                    MaxWidth="300"
                                    HorizontalAlignment="Left"
                                    Background="#303030">
                                <StackPanel>
                                    <TextBlock x:Name="SenderText" Text="{Binding Username}" Foreground="#a0a0a0" FontSize="12" Margin="0,0,0,4" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Text}" Foreground="#e0e0e8" FontSize="14" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="TimeText" Text="{Binding DisplayTime}" Foreground="#8e9297" FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsOwnMessage}" Value="True">
                                <Setter TargetName="MessageBorder" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="MessageBorder" Property="Background" Value="#5865f2"/>
                                <Setter TargetName="SenderText" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                <Setter TargetName="MessageBorder" Property="HorizontalAlignment" Value="Center"/>
                                <Setter TargetName="MessageBorder" Property="Background" Value="Transparent"/>
                                <Setter TargetName="SenderText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="TimeText" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="3"
                Background="#20202c"
                CornerRadius="8"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageBox"
                         Grid.Column="0"
                         Style="{StaticResource RoundedTextBox}"
                         IsEnabled="False"
                         Margin="0,0,8,0"
                         PreviewKeyDown="MessageBox_PreviewKeyDown"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send"
                        Style="{StaticResource AccentButton}"
                        IsEnabled="False"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>